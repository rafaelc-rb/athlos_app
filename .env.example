# Copy to .env and fill with your project values.
# Used by Makefile and scripts/build_release.sh.
# Do not commit .env.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_legacy_jwt
GEMINI_API_KEY=your_gemini_api_key

# Optional runtime/device defaults used by Makefile.
# iOS simulator target name (preferred) or set SIM_UDID in your shell.
SIM_DEVICE=your_ios_simulator_name
# Optional: iOS simulator UDID (overrides SIM_DEVICE when provided).
SIM_UDID=your_ios_simulator_udid
# Physical iPhone UDID for `make run-ios-prod`.
IOS_DEVICE_UDID=your_ios_device_udid
# Android AVD for `make run-android`.
ANDROID_EMULATOR=your_android_avd_name
